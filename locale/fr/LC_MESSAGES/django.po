msgid "5-Minute Online Lessons"
msgstr "Leçons en ligne de 5 minutes"

msgid "A super-light conversation platform for people who want to talk with someone right now."
msgstr "Une plateforme de conversation ultra légère pour les personnes qui veulent parler avec quelqu’un immédiatement."

msgid "Select a language and start a 5-minute lesson."
msgstr "Choisissez une langue et commencez une leçon de 5 minutes."

msgid "Start a 5-Minute Lesson Now"
msgstr "Commencer une leçon de 5 minutes"

msgid "You need to log in to start a lesson."
msgstr "Vous devez vous connecter pour commencer une leçon."

msgid "Log In"
msgstr "Connexion"

msgid "How does it work?"
msgstr "Comment ça marche ?"

msgid "1. Teachers switch their status to “Online” and wait."
msgstr "1. Les professeurs passent en ligne et attendent."

msgid "2. Students choose a language and click “Start a 5-minute lesson now”."
msgstr "2. Les étudiants choisissent une langue et cliquent sur « Commencer une leçon de 5 minutes »."

msgid "3. The system randomly matches an available teacher."
msgstr "3. Le système associe automatiquement un professeur disponible."

msgid "4. Join the meeting URL and talk for 5 minutes."
msgstr "4. Rejoignez le lien de réunion et parlez pendant 5 minutes."

msgid "Talk for 5 Minutes Now"
msgstr "Parler pendant 5 minutes"

msgid "Step 1"
msgstr "Étape 1"

msgid "Select the language you want to practice. If any tutors are online, you will be randomly matched."
msgstr "Choisissez la langue que vous souhaitez pratiquer. Si des professeurs sont en ligne, vous serez associé aléatoirement."

msgid "Select a language"
msgstr "Choisissez une langue"

msgid "Start a 5-Minute Lesson"
msgstr "Commencer une leçon de 5 minutes"

msgid "Cancel"
msgstr "Annuler"

msgid "Matching Result"
msgstr "Résultat du matching"

msgid "Your 5-minute lesson is ready."
msgstr "Votre leçon de 5 minutes est prête."

